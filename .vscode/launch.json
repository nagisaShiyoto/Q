{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "eylon client",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\client.py",
            "console": "integratedTerminal",
            "args": ["127.0.0.1", "1234", "eylon", "no"]
        },
        {
            "name": "random client",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\client.py",
            "console": "integratedTerminal",
            "args": ["127.0.0.1", "1234", "random_name", "no"]
        },
        {
            "name": "admin",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\client.py",
            "console": "integratedTerminal",
            "args": ["127.0.0.1", "1234", "admin", "*password"]
        },
        {
            "name": "server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\server.py",
            "console": "integratedTerminal",
            "args": ["1234"]
        },
    ]
}