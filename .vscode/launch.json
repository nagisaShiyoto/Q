    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "client",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\client.py",
            "console": "integratedTerminal",
        },
        {
            "name": "server",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}\\server.py",
            "console": "integratedTerminal",
        },
    ]
}